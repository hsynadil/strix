{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Strix",
  "version": "0.3.0",
  "identifier": "com.hsynadil.strix",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Strix — Process Monitor",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480
      },
      {
        "label": "osd",
        "url": "osd.html",
        "title": "Strix OSD",
        "width": 240,
        "height": 34,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/sensors/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
